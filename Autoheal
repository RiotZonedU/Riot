local RunService = game:GetService("RunService")
local UserInputService = game:GetService("UserInputService")
local Players = game:GetService("Players")

local TRIGGER_HEALTH = 50
local BURST_FPS = 25
local BURST_DELAY = 1 / BURST_FPS
local MAX_HEALTH = 100
local BURST_COUNT = 2

local isRunning = false
local accumulator = 0
local burstCounter = 0
local packetsPerBurst = 0
local currentBurst = 0
local wasBelowThreshold = false

local function getLayoutOrder()
    local success, layoutOrder = pcall(function()
        local bloodfruitButton = Players.LocalPlayer.PlayerGui.MainGui.RightPanel.Inventory.List.Bloodfruit
        if bloodfruitButton then
            return bloodfruitButton.LayoutOrder
        end
        return 1
    end)
    
    if not success then
        return 1
    end
    
    return layoutOrder or 1
end

local function createPacketsBasedOnHealth(health)
    local healthLost = MAX_HEALTH - health
    local packetsNeeded = math.floor(healthLost / 3)
    local extraPacket = 1
    local totalPackets = math.max(packetsNeeded + extraPacket, 1)
    
    local layoutOrder = getLayoutOrder()
    
    local packetString = ""
    for i = 1, totalPackets do
        packetString = packetString .. "\000." .. string.char(layoutOrder) .. "\000"
    end
    
    return {buffer.fromstring(packetString)}
end

local function fixedUpdate(deltaTime)
    if not isRunning then return end
    
    accumulator += deltaTime
    
    if accumulator >= BURST_DELAY then
        local player = Players.LocalPlayer
        local character = player.Character
        
        if character then
            local humanoid = character:FindFirstChildOfClass("Humanoid")
            if humanoid then
                local health = humanoid.Health
                
                if health >= TRIGGER_HEALTH then
                    isRunning = false
                    burstCounter = 0
                    accumulator = 0
                    currentBurst = 0
                    return
                end
                
                local args = createPacketsBasedOnHealth(health)
                local remote = game:GetService("ReplicatedStorage"):WaitForChild("ByteNetReliable")
                remote:FireServer(unpack(args))
                
                burstCounter = burstCounter + 1
                accumulator = accumulator - BURST_DELAY
                
                if burstCounter >= BURST_COUNT then
                    isRunning = false
                    burstCounter = 0
                    currentBurst = 0
                end
            else
                isRunning = false
                burstCounter = 0
                accumulator = 0
                currentBurst = 0
            end
        else
            isRunning = false
            burstCounter = 0
            accumulator = 0
            currentBurst = 0
        end
    end
end

local function checkHealth()
    local player = Players.LocalPlayer
    local character = player.Character
    
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local health = humanoid.Health
    
    if health < TRIGGER_HEALTH then
        if not wasBelowThreshold and not isRunning then
            isRunning = true
            burstCounter = 0
            accumulator = 0
            currentBurst = 0
            wasBelowThreshold = true
        end
    else
        wasBelowThreshold = false
    end
end

local function toggleSpammer()
    local player = Players.LocalPlayer
    local character = player.Character
    
    if not character then return end
    
    local humanoid = character:FindFirstChildOfClass("Humanoid")
    if not humanoid then return end
    
    local health = humanoid.Health
    
    if health >= TRIGGER_HEALTH then
        return
    end
    
    if not isRunning then
        isRunning = true
        burstCounter = 0
        accumulator = 0
        currentBurst = 0
        wasBelowThreshold = true
    else
        isRunning = false
        burstCounter = 0
        accumulator = 0
        currentBurst = 0
    end
end

RunService.Heartbeat:Connect(fixedUpdate)

RunService.Heartbeat:Connect(function()
    checkHealth()
end)

UserInputService.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.DPadDown then
        toggleSpammer()
    end
end)