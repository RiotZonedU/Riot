local player = game.Players.LocalPlayer
local replicatedStorage = game:GetService("ReplicatedStorage")
local runService = game:GetService("RunService")
local tweenService = game:GetService("TweenService")

local byteNet = replicatedStorage:WaitForChild("ByteNetReliable")
local notificationsFrame = player.PlayerGui:WaitForChild("MainGui"):WaitForChild("Subordinates"):WaitForChild("Notifications")
local textTemplate = notificationsFrame:WaitForChild("Templates"):WaitForChild("TextLabel")

local packetId = "1"

local args = {
    buffer.fromstring("\000" .. packetId .. "\001\000\000" .. packetId .. "\001\000\000" .. packetId .. "\001\000")
}

local active = false
local currentHumanoid = nil
local renderConnection = nil
local healthConnection = nil
local heartbeatConnection = nil

local function createNotification()
    local existingNotifications = {}
    for _, child in ipairs(notificationsFrame:GetChildren()) do
        if child:IsA("TextLabel") and child ~= textTemplate then
            table.insert(existingNotifications, child)
        end
    end
    
    if #existingNotifications >= 3 then
        existingNotifications[1]:Destroy()
    end
    
    local newNotification = textTemplate:Clone()
    newNotification.Parent = notificationsFrame
    newNotification.Visible = true
    newNotification.Text = "Ate Bloodfruit!"
    newNotification.TextColor3 = Color3.fromRGB(170, 255, 0)
    
    local fadeOut = tweenService:Create(
        newNotification,
        TweenInfo.new(2, Enum.EasingStyle.Linear),
        {TextTransparency = 1, BackgroundTransparency = 1}
    )
    
    fadeOut:Play()
    fadeOut.Completed:Wait()
    newNotification:Destroy()
end

local function fireByteEvent()
    byteNet:FireServer(unpack(args))
    createNotification()
end

local function startFiring()
    if active then return end
    active = true
    
    if not renderConnection then
        renderConnection = runService.RenderStepped:Connect(function()
            if currentHumanoid and currentHumanoid.Health < 100 and currentHumanoid.Health > 0 then
                fireByteEvent()
            elseif currentHumanoid and currentHumanoid.Health >= 100 then
                stopFiring()
            end
        end)
    end
    
    if not heartbeatConnection then
        heartbeatConnection = runService.Heartbeat:Connect(function()
            if currentHumanoid and currentHumanoid.Health < 100 and currentHumanoid.Health > 0 then
                fireByteEvent()
            elseif currentHumanoid and currentHumanoid.Health >= 100 then
                stopFiring()
            end
        end)
    end
end

local function stopFiring()
    active = false
    if renderConnection then
        renderConnection:Disconnect()
        renderConnection = nil
    end
    if heartbeatConnection then
        heartbeatConnection:Disconnect()
        heartbeatConnection = nil
    end
end

local function onHealthChanged(health)
    if health < 50 and not active then
        startFiring()
    elseif health >= 100 and active then
        stopFiring()
    end
end

local function setupCharacter(character)
    if healthConnection then
        healthConnection:Disconnect()
        healthConnection = nil
    end
    
    currentHumanoid = character:WaitForChild("Humanoid")
    
    healthConnection = currentHumanoid.HealthChanged:Connect(onHealthChanged)
    
    if currentHumanoid.Health < 50 then
        startFiring()
    elseif currentHumanoid.Health >= 100 then
        stopFiring()
    end
end

player.CharacterAdded:Connect(setupCharacter)

if player.Character then
    setupCharacter(player.Character)
end
