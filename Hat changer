local function scheduleSave(configData)
    pendingConfigData = configData
    if saveScheduled then return end
    saveScheduled = true
    task.delay(0.6, function()
        pcall(function()
            makefolder(configFolder)
            writefile(configFile, game:GetService("HttpService"):JSONEncode(pendingConfigData or {}))
        end)
        saveScheduled = false
        pendingConfigData = nil
    end)
end

local function saveConfig()
    local configData = {}
    for _, hatData in ipairs(hats) do
        local isEquipped = equippedHats[hatData.name] ~= nil
        local isVisible = false
        local cosmeticList = getCosmeticList()
        if cosmeticList then
            for _, frame in ipairs(cosmeticList:GetChildren()) do
                if frame:IsA("Frame") and frame.Name:lower() == hatData.name:lower() then
                    isVisible = frame.Visible
                    break
                end
            end
        end
        configData[hatData.name] = {equipped = isEquipped, visible = isVisible}
    end
    scheduleSave(configData)
end

local function createParticle(parent, properties)
    local particleEmitter = Instance.new("ParticleEmitter")

    particleEmitter.Brightness = properties.Brightness or 1
    particleEmitter.LightEmission = properties.LightEmission or 0.5
    particleEmitter.LightInfluence = properties.LightInfluence or 0.5
    particleEmitter.Orientation = properties.Orientation or Enum.ParticleOrientation.FacingCamera
    particleEmitter.Texture = properties.Texture or ""
    particleEmitter.Lifetime = properties.Lifetime or NumberRange.new(0.25, 0.75)
    particleEmitter.Rate = properties.Rate or 50
    particleEmitter.Rotation = properties.Rotation or NumberRange.new(-180, 180)
    particleEmitter.RotSpeed = properties.RotSpeed or NumberRange.new(80, 80)
    particleEmitter.Speed = properties.Speed or NumberRange.new(5, 5)
    particleEmitter.SpreadAngle = properties.SpreadAngle or Vector2.new(0, 12)
    particleEmitter.Shape = properties.Shape or Enum.ParticleEmitterShape.Box

    local color = properties.Color
    if color then
        local colorKeypoints = {
            ColorSequenceKeypoint.new(0, color),
            ColorSequenceKeypoint.new(1, color)
        }
        particleEmitter.Color = ColorSequence.new(colorKeypoints)
    else
        local colorKeypoints = {
            ColorSequenceKeypoint.new(0, Color3.fromRGB(0, 0, 0)),
            ColorSequenceKeypoint.new(1, Color3.fromRGB(0, 0, 0))
        }
        particleEmitter.Color = ColorSequence.new(colorKeypoints)
    end

    local size = properties.Size
    if size then
        particleEmitter.Size = size
    else
        local sizeKeypoints = {
            NumberSequenceKeypoint.new(0, 0.25),
            NumberSequenceKeypoint.new(1, 0)
        }
        particleEmitter.Size = NumberSequence.new(sizeKeypoints)
    end

    local transparency = properties.Transparency
    if transparency then
        particleEmitter.Transparency = transparency
    else
        local transparencyKeypoints = {
            NumberSequenceKeypoint.new(0, 1),
            NumberSequenceKeypoint.new(0.586035, 0.45625),
            NumberSequenceKeypoint.new(1, 0)
        }
        particleEmitter.Transparency = NumberSequence.new(transparencyKeypoints)
    end

    particleEmitter.Parent = parent
    particleEmitter.Enabled = true
    return particleEmitter
end

local function startParticle(hatPart, hatName)
    if not hatPart or not hatParticles[hatName] then return end

    local particleName = hatName .. "Particle"
    local existingParticle = hatPart:FindFirstChild(particleName)
    if existingParticle then
        existingParticle.Enabled = true
        return
    end

    createParticle(hatPart, hatParticles[hatName])
end

local function stopParticle(hatPart, hatName)
    if not hatPart then return end

    local particleName = hatName .. "Particle"
    local particle = hatPart:FindFirstChild(particleName)
    if particle then
        particle.Enabled = false
        task.delay(1, function()
            if particle and particle.Parent then
                particle:Destroy()
            end
        end)
    end
end

local function animateDiscoFire(fire)
    if not fire or not fire.Parent then return end

    local secondaryColor = Color3.fromRGB(214, 244, 252)
    local colorIndex = 1
    fire.SecondaryColor = secondaryColor
    fire.Enabled = true

    local hatPart = fire.Parent
    local animatingFlag = Instance.new("BoolValue")
    animatingFlag.Name = "IsAnimating"
    animatingFlag.Parent = fire

    while fire and fire.Parent and hatPart and hatPart.Parent do
        local targetColor = Color3.fromRGB(colorSequence[colorIndex][1], colorSequence[colorIndex][2], colorSequence[colorIndex][3])
        local startColor = fire.Color
        local startTime = tick()

        while tick() - startTime < 0.1 do
            if not fire or not fire.Parent or not hatPart.Parent then 
                fire.Enabled = false
                if animatingFlag then animatingFlag:Destroy() end
                return 
            end
            local alpha = (tick() - startTime) / 0.1
            fire.Color = startColor:Lerp(targetColor, alpha)
            task.wait()
        end
        fire.Color = targetColor
        colorIndex = colorIndex % #colorSequence + 1
        task.wait(0.1)
    end

    if animatingFlag then animatingFlag:Destroy() end
end

local function startDiscoHornsAnimation(hatPart)
    if not hatPart then return end

    for _, child in ipairs(hatPart:GetChildren()) do
        if child:IsA("Fire") and not child:FindFirstChild("IsAnimating") then
            coroutine.wrap(function() animateDiscoFire(child) end)()
            break
        end
    end
end

local function stopDiscoHornsAnimation(hatPart)
    if not hatPart then return end

    for _, child in ipairs(hatPart:GetChildren()) do
        if child:IsA("Fire") then
            child.Enabled = false
            local animatingFlag = child:FindFirstChild("IsAnimating")
