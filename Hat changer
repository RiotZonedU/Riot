local function removeOldestHat()
    if #hatOrder > 0 then
        local oldestHatName = hatOrder[1]
        local hatToRemove = equippedHats[oldestHatName]

        if hatToRemove then
            if oldestHatName == "Disco Horns" then
                stopDiscoHornsAnimation(hatToRemove)
            end

            if hatParticles[oldestHatName] then
                stopParticle(hatToRemove, oldestHatName)
            end

            hatToRemove:Destroy()
            equippedHats[oldestHatName] = nil

            updateCosmeticFrameUI(oldestHatName, false)

            if oldestHatName == "Headless Head" and character and character.Head then
                character.Head.Transparency = 0
                local face = character.Head:FindFirstChild("face") or character.Head:FindFirstChild("Face")
                if face then face.Transparency = 0 end
            end

            table.remove(hatOrder, 1)
            saveConfig()

            syncUIWithEquippedState()
        end
    end
end

local function startHatEffects(hatPart, hatName)
    if hatName == "Disco Horns" then
        startDiscoHornsAnimation(hatPart)
    end

    if hatParticles[hatName] then
        startParticle(hatPart, hatName)
    end
end

local function stopHatEffects(hatPart, hatName)
    if hatName == "Disco Horns" then
        stopDiscoHornsAnimation(hatPart)
    end

    if hatParticles[hatName] then
        stopParticle(hatPart, hatName)
    end
end

local function toggleHat(hatData)
    if not character or not character.Head then return end

    if equippedHats[hatData.name] then
        local hatToRemove = equippedHats[hatData.name]

        stopHatEffects(hatToRemove, hatData.name)

        hatToRemove:Destroy()
        equippedHats[hatData.name] = nil
        updateCosmeticFrameUI(hatData.name, false)

        for i, name in ipairs(hatOrder) do
            if name == hatData.name then
                table.remove(hatOrder, i)
                break
            end
        end

        if hatData.name == "Headless Head" and character.Head then
            character.Head.Transparency = 0
            local face = character.Head:FindFirstChild("face") or character.Head:FindFirstChild("Face")
            if face then face.Transparency = 0 end
        end
        saveConfig()
    else
        if #hatOrder >= 2 then
            removeOldestHat()
        end

        local hat = createHat(hatData)
        if hat then
            equippedHats[hatData.name] = hat
            table.insert(hatOrder, hatData.name)

            startHatEffects(hat, hatData.name)

            if hatData.name == "Headless Head" and character.Head then
                character.Head.Transparency = 1
                local face = character.Head:FindFirstChild("face") or character.Head:FindFirstChild("Face")
                if face then face.Transparency = 1 end
            end
            saveConfig()
        end
    end

    syncUIWithEquippedState()
end

local function setupClickConnections()
    pcall(function()
        local cosmeticList = getCosmeticList()
        if cosmeticList then
            for _, frame in ipairs(cosmeticList:GetChildren()) do
                if frame:IsA("Frame") then
                    for _, hatData in ipairs(hats) do
                        if frame.Name:lower() == hatData.name:lower() then
                            local function onClick()
                                if character and character.Head then toggleHat(hatData) end
                            end
                            for _, child in ipairs(frame:GetChildren()) do
                                if child:IsA("ImageButton") or child:IsA("TextButton") then
                                    child.MouseButton1Click:Connect(onClick)
                                elseif child:IsA("TextLabel") then
                                    child.InputBegan:Connect(function(input)
                                        if input.UserInputType == Enum.UserInputType.MouseButton1 then onClick() end
                                    end)
                                end
                            end
                            break
                        end
                    end
                end
            end
        end
    end)
end

