        if cosmeticList and optionsList then
            for _, frame in ipairs(cosmeticList:GetChildren()) do
                if frame:IsA("Frame") and frame.Name:lower() == hatName:lower() then
                    for i, button in ipairs(optionsList:GetChildren()) do
                        if button:IsA("TextButton") and button.Text:sub(5) == hatName then
                            if frame.Visible then button.Text = "[X] "..hatName
                            else button.Text = "[ ] "..hatName end
                            break
                        end
                    end
                    break
                end
            end
        end
    end)
end

