local function loadConfig()
    local success, data = pcall(function() return readfile(configFile) end)
    if success and data and data ~= "" then
        local success2, configData = pcall(function() return game:GetService("HttpService"):JSONDecode(data) end)
        if success2 and type(configData) == "table" then
            local hatsToCreate = {}
            for name, data in pairs(configData) do
                if data.equipped then
                    table.insert(hatsToCreate, name)
                end
                if data.visible then
                    for i, hatData in ipairs(hats) do
                        if hatData.name == name then
                            setCosmeticFrameVisible(hatData.name, true)
                            break
                        end
                    end
                end
            end
            if #hatsToCreate > 0 then
                for _, name in ipairs(hatsToCreate) do
                    for i, hatData in ipairs(hats) do
                        if hatData.name == name then
                            if #hatOrder >= 2 then
                                removeOldestHat()
                            end
                            local hat = createHat(hatData)
                            if hat then
                                equippedHats[hatData.name] = hat
                                table.insert(hatOrder, hatData.name)
                                startHatEffects(hat, hatData.name)

                                if hatData.name == "Headless Head" and character and character.Head then
                                    character.Head.Transparency = 1
                                    local face = character.Head:FindFirstChild("face") or character.Head:FindFirstChild("Face")
                                    if face then face.Transparency = 1 end
                                end
                            end
                            break
                        end
                    end
                    task.wait()
                end
            end
            syncUIWithEquippedState()
        end
    end
end

