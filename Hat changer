local function onAccessoryAdded(instance)
    if instance:IsA("Accessory") then
        pcall(function() instance:Destroy() end)
    end
end

local function setupDeletionConnections()
    if deletionSetupDone then return end
    deletionSetupDone = true

    if character then
        if deletionConnection then
            deletionConnection:Disconnect()
            deletionConnection = nil
        end
        deletionConnection = character.DescendantAdded:Connect(onAccessoryAdded)
        for _, descendant in ipairs(character:GetDescendants()) do
            if descendant:IsA("Accessory") then
                pcall(function() descendant:Destroy() end)
            end
        end
    end

    local playersFolder = workspace:FindFirstChild("Players")
    if playersFolder then
        local playerFolder = playersFolder:FindFirstChild(player.Name)
        if playerFolder then
            playerFolder.ChildAdded:Connect(function(child)
                if child.Name == "God Halo" then
                    task.wait()
                    pcall(function()
                        local handle = child:FindFirstChild("Handle")
                        if handle and handle.Transparency ~= 1 then handle.Transparency = 1 end
                    end)
                end
            end)

            local godHalo = playerFolder:FindFirstChild("God Halo")
            if godHalo then
                pcall(function()
                    local handle = godHalo:FindFirstChild("Handle")
                    if handle and handle.Transparency ~= 1 then handle.Transparency = 1 end
                end)
            end
        end
    end
end

local function updateButtonIndicator(hatName)
    pcall(function()
