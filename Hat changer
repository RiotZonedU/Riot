local function isGameLoaded()
    local mainGui = player.PlayerGui:FindFirstChild("MainGui")
    if not mainGui then return false end
    local leftPanel = mainGui:FindFirstChild("LeftPanel")
    if not leftPanel then return false end
    local shop = leftPanel:FindFirstChild("Shop")
    if not shop then return false end
    local lists = shop:FindFirstChild("Lists")
    if not lists then return false end
    local cosmeticList = lists:FindFirstChild("CosmeticList")
    if not cosmeticList then return false end
    return true
end

local function getCosmeticList()
    if cosmeticListRef and cosmeticListRef.Parent then return cosmeticListRef end
    local mainGui = player.PlayerGui:FindFirstChild("MainGui")
    if mainGui then
        local leftPanel = mainGui:FindFirstChild("LeftPanel")
        if leftPanel then
            local shop = leftPanel:FindFirstChild("Shop")
            if shop then
                local lists = shop:FindFirstChild("Lists")
                if lists then
                    local cosmeticList = lists:FindFirstChild("CosmeticList")
                    cosmeticListRef = cosmeticList
                    return cosmeticListRef
                end
            end
        end
    end
    return nil
end

