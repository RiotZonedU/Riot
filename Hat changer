        if mainGui then
            local panels = mainGui:FindFirstChild("Panels")
            if panels then
                local confirm1 = panels:FindFirstChild("ConfirmEventPurchase")
                if confirm1 then confirm1:Destroy() end
                local confirm2 = panels:FindFirstChild("ConfirmPurchaseYe")
                if confirm2 then confirm2:Destroy() end
            end
